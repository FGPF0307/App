# Salin file ini menjadi `.env` lalu isi nilainya.
# Ambil dari Supabase Dashboard > Project Settings > API.

# Project URL (sama dengan yang dipakai aplikasi Flutter)
SUPABASE_URL=https://lloibeyejbqfqklnimtn.supabase.co

# service_role secret (BUKAN anon/publishable). Settings > API > Project API keys.
# JANGAN commit nilai asli ke GitHub.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Port server (opsional, default 3000)
PORT=3000
